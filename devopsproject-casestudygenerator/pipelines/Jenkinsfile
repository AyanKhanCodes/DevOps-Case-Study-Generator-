pipeline {
    agent any

    tools {
        nodejs 'node-v20' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test (Node)') {
            steps {
                sh 'npm ci'
                sh 'npm run test'
            }
        }

        stage('UI Test (Python/Selenium)') {
            steps {
                sh '''
                python3 -m venv venv
                . venv/bin/activate
                pip install pytest selenium
                python3 -m pytest tests/selenium/
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t devopsproject-casestudygenerator:latest .'
            }
        }
    }
}

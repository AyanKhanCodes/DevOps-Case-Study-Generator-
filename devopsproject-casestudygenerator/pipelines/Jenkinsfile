pipeline {
    agent any

    environment {
        PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test (Node)') {
            steps {
                dir('devopsproject-casestudygenerator') {
                    sh 'npm ci'
                    sh 'npm run test'
                }
            }
        }

        stage('UI Test (Python/Selenium)') {
            steps {
                dir('devopsproject-casestudygenerator') {
                    sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install pytest selenium
                    python3 -m pytest tests/selenium/
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('devopsproject-casestudygenerator') {
                    sh 'docker build -t devopsproject-casestudygenerator:latest -f infrastructure/docker/Dockerfile .'
                }
            }
        }
    }
}

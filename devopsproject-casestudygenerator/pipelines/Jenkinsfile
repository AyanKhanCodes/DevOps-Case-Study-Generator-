pipeline {
    agent any

    

    stages {
        stage('Checkout') {
            steps {
                // Checkout pulls the whole repo, so we leave this alone
                checkout scm
            }
        }

        stage('Test (Node)') {
            steps {
                // Step inside the project folder to find package.json
                dir('devopsproject-casestudygenerator') {
                    sh 'npm ci'
                    sh 'npm run test'
                }
            }
        }

        stage('UI Test (Python/Selenium)') {
            steps {
                // Step inside the project folder to find the tests directory
                dir('devopsproject-casestudygenerator') {
                    sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install pytest selenium
                    python3 -m pytest tests/selenium/
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                // Step inside the project folder to find the Dockerfile
                dir('devopsproject-casestudygenerator') {
                    sh 'docker build -t devopsproject-casestudygenerator:latest .'
                }
            }
        }
    }
}
